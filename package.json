{
  "name": "pi-var",
  "version": "1.0.1",
  "description": "Copy-on-write variations for pi — work on multiple features simultaneously with isolated workspaces",
  "keywords": [
    "pi-package",
    "worktree",
    "copy-on-write",
    "workspace",
    "variations"
  ],
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint:dead": "knip --no-gitignore",
    "postinstall": "simple-git-hooks 2>/dev/null || true"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "npm run typecheck && npm run test",
    "commit-msg": "npx commitlint --edit ${1}"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "knip": "6.14.1",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "simple-git-hooks": "2.13.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7",
    "@earendil-works/pi-tui": "0.79.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.74.0",
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@sinclair/typebox": "0.34.49"
  },
  "overrides": {
    "brace-expansion": "5.0.6",
    "fast-xml-builder": "1.2.0",
    "protobufjs": "8.4.0",
    "ws": "8.20.1"
  },
  "packageManager": "pnpm@11.6.0"
}
